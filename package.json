{
  "name": "lookmom",
  "version": "0.1.0",
  "private": true,
  "description": "lookmom — Claude-published, access-controlled HTML pages on Cloudflare",
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "bun@1.3.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "bun run --filter '*' typecheck",
    "deploy": "bun run --filter @lookmom/worker deploy",
    "db:generate": "bun run --filter @lookmom/worker db:generate",
    "db:migrate:remote": "bun run --filter @lookmom/worker db:migrate:remote"
  },
  "devDependencies": {
    "turbo": "^2.10.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
